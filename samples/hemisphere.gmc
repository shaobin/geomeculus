theta = v1
phi = v2

# sphere
M = sin($theta) * cos($phi) * e1 + sin($theta) * sin($phi) * e2 + cos($theta) * e3

partial_derivative($M, 1)
partial_derivative($M, 2)

A = vector_derivative(v1, $M, 2)
B = vector_derivative(v2, $M, 2)
C = vector_derivative(cos($theta), $M, 2)

A1 = $A; v1=0.1;v2=0
A2 = $A; v1=0.1;v2=3.14159265358979323846
B1 = $B; v1=0.1;v2=0
B2 = $B; v1=0.1;v2=3.14159265358979323846
C1 = $C; v1=0.1;v2=0
C2 = $C; v1=0.1;v2=3.14159265358979323846
outer_product($A1, $B1) * $C1
outer_product($A2, $B2) * $C2

A3 = $A; v1=0.5;v2=0
A4 = $A; v1=0.5;v2=3.14159265358979323846
B3 = $B; v1=0.5;v2=0
B4 = $B; v1=0.5;v2=3.14159265358979323846
C3 = $C; v1=0.5;v2=0
C4 = $C; v1=0.5;v2=3.14159265358979323846
outer_product($A3, $B3) * $C3
outer_product($A4, $B4) * $C4

# pi/4 = 0.785398163397448309616
A5 = $A; v1=0.785398163397448309616;v2=0
A6 = $A; v1=0.785398163397448309616;v2=3.14159265358979323846
B5 = $B; v1=0.785398163397448309616;v2=0
B6 = $B; v1=0.785398163397448309616;v2=3.14159265358979323846
C5 = $C; v1=0.785398163397448309616;v2=0
C6 = $C; v1=0.785398163397448309616;v2=3.14159265358979323846
outer_product($A5, $B5) * $C5
outer_product($A6, $B6) * $C6

# pi/2 = 1.57079632679489661923
A7 = $A; v1=1.57079632679489661923;v2=0
A8 = $A; v1=1.57079632679489661923;v2=3.14159265358979323846
B7 = $B; v1=1.57079632679489661923;v2=0
B8 = $B; v1=1.57079632679489661923;v2=3.14159265358979323846
C7 = $C; v1=1.57079632679489661923;v2=0
C8 = $C; v1=1.57079632679489661923;v2=3.14159265358979323846
outer_product($A7, $B7) * $C7
outer_product($A8, $B8) * $C8
